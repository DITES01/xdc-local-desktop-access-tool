<UserControl x:Class="XdcLocalDesktopAccessTool.App.Controls.MnemonicPhraseGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style x:Key="MnemonicSlotBase" TargetType="Grid">
            <Setter Property="Margin" Value="6,2,6,2"/>
        </Style>

        <Style x:Key="MnemonicIndexBadge" TargetType="Border">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="23"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#F7F7F7"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MnemonicWordBox" TargetType="TextBox">
            <Setter Property="Height" Value="23"/>
            <Setter Property="Padding" Value="6,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <!-- LOCKED HEIGHT — DO NOT CHANGE -->
    <Border Height="205">
        <Grid>
            <Grid x:Name="MnemonicGrid"/>
        </Grid>
    </Border>

</UserControl>