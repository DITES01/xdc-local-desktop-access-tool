<UserControl x:Class="XdcLocalDesktopAccessTool.App.Views.Controls.ThankYouOverlayControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Width="480"
            Height="265"
            Background="#EFEFEF"
            BorderBrush="#6F6F6F"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <Grid Background="#EFEFEF">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Thank you for supporting this project."
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,0"/>

            <Border Grid.Row="2"
                    BorderBrush="#6F6F6F"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#EFEFEF"
                    Padding="18,16">

                <Grid Background="#EFEFEF">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                MaxWidth="360">

                        <TextBlock Text="Your donation helps keep the XDC Local Desktop Access Tool maintained and improved."
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Coffee levels restored. Development may continue."
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="13"/>
                    </StackPanel>

                    <Button Grid.Row="1"
                            Content="Close"
                            Width="110"
                            Height="30"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,0"
                            Click="Close_Click"/>
                </Grid>

            </Border>
        </Grid>
    </Border>

</UserControl>
