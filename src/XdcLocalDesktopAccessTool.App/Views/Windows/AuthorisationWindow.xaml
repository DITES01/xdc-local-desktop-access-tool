<Window x:Class="XdcLocalDesktopAccessTool.App.Views.Windows.AuthorisationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Authorisation Required (Local Signing)"
        Width="1000"
        Height="795"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Authorisation Required (Local Signing)"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <TextBlock TextWrapping="Wrap">
                <Run Text="Authorisation is required to use local signing features (Send tab)."/>
                <LineBreak/>
                <Run Text="Secrets are not written to disk. Passwords are never stored."/>
                <LineBreak/>
                <Run Text="Authorisation is memory-only and clears on Deauthorise or app close."/>
            </TextBlock>
        </StackPanel>

        <TabControl x:Name="AuthTabControl"
                    Grid.Row="1"
                    PreviewMouseLeftButtonDown="AuthTabControl_PreviewMouseLeftButtonDown"
                    SelectionChanged="AuthTabControl_SelectionChanged">

            <TabItem Header="Keystore (JSON) — Recommended">
                <Grid Margin="10">
                    <Border BorderBrush="#BFBFBF"
                            BorderThickness="1"
                            Padding="12"
                            Width="700"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="Transparent">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="500"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="Keystore file:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <TextBox x:Name="KeystorePathTextBox"
                                     Grid.Row="0" Grid.Column="1"
                                     MinHeight="28"
                                     Height="28"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,8,0"
                                     TextChanged="AuthInputs_Changed"/>

                            <Button Grid.Row="0" Grid.Column="2"
                                    Content="Browse..."
                                    Width="90"
                                    MinHeight="28"
                                    Click="BrowseKeystore_Click"/>

                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="Password:"
                                       VerticalAlignment="Center"
                                       Margin="0,10,8,0"/>

                            <Grid Grid.Row="1" Grid.Column="1" Margin="0,10,8,0">
                                <Grid>
                                    <PasswordBox x:Name="KeystorePasswordBox"
                                                 MinHeight="28"
                                                 Height="28"
                                                 Padding="6,2"
                                                 VerticalContentAlignment="Center"
                                                 PasswordChanged="AuthInputs_Changed"/>

                                    <TextBox x:Name="KeystorePasswordTextBox"
                                             Visibility="Collapsed"
                                             MinHeight="28"
                                             Height="28"
                                             Padding="6,2"
                                             VerticalContentAlignment="Center"
                                             TextChanged="AuthInputs_Changed"/>
                                </Grid>
                            </Grid>

                            <CheckBox x:Name="ShowPasswordCheckBox"
                                      Grid.Row="2" Grid.Column="1"
                                      Margin="0,10,0,0"
                                      Content="Show password"
                                      Checked="ShowPasswordCheckBox_Checked"
                                      Unchecked="ShowPasswordCheckBox_Unchecked"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Recovery Phrase — Advanced">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Phrase length"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <ComboBox x:Name="PhraseLengthComboBox"
                                  Grid.Column="1"
                                  Width="140"
                                  Height="26"
                                  SelectedIndex="0"
                                  SelectionChanged="PhraseLengthComboBox_SelectionChanged">
                            <ComboBoxItem Content="12 words"/>
                            <ComboBoxItem Content="24 words"/>
                        </ComboBox>

                        <CheckBox x:Name="UsePassphraseCheckBox"
                                  Grid.Column="3"
                                  Content="Use BIP39 passphrase (advanced)"
                                  VerticalAlignment="Center"
                                  Margin="0,0,18,0"
                                  Checked="UsePassphraseCheckBox_Changed"
                                  Unchecked="UsePassphraseCheckBox_Changed"/>

                        <CheckBox x:Name="ShowPhraseCheckBox"
                                  Grid.Column="4"
                                  Content="Show recovery phrase while typing"
                                  VerticalAlignment="Center"
                                  Checked="ShowPhraseCheckBox_Changed"
                                  Unchecked="ShowPhraseCheckBox_Changed"/>
                    </Grid>

                    <Grid x:Name="PassphraseRowGrid"
                          Grid.Row="1"
                          Visibility="Hidden"
                          Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Passphrase"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <Grid Grid.Column="1" VerticalAlignment="Center">
                            <PasswordBox x:Name="PassphrasePasswordBox"
                                         Height="26"
                                         Padding="6,2"
                                         PasswordChanged="PassphrasePasswordBox_PasswordChanged"/>

                            <TextBox x:Name="PassphraseTextBox"
                                     Height="26"
                                     Padding="6,2"
                                     Visibility="Collapsed"
                                     TextChanged="PassphraseTextBox_TextChanged"/>
                        </Grid>

                        <CheckBox x:Name="ShowBip39PassphraseCheckBox"
                                  Grid.Column="3"
                                  Content="Show passphrase"
                                  VerticalAlignment="Center"
                                  IsEnabled="False"
                                  Checked="ShowBip39PassphraseCheckBox_Checked"
                                  Unchecked="ShowBip39PassphraseCheckBox_Unchecked"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Recovery phrase"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <Border Grid.Row="1"
                                BorderBrush="#6F6F6F"
                                BorderThickness="1"
                                Padding="4">

                            <ItemsControl x:Name="WordsItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" Rows="6"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="WordCellRoot" Margin="5,1,5,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                                            <Setter Property="Visibility" Value="Hidden"/>
                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Width="26"
                                                        Height="26"
                                                        VerticalAlignment="Center"
                                                        BorderBrush="#D0D0D0"
                                                        BorderThickness="1"
                                                        Background="#F7F7F7"
                                                        Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding DisplayIndex}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="#333"/>
                                                </Border>

                                                <TextBox x:Name="WordTextBox"
                                                         Grid.Column="1"
                                                         Height="26"
                                                         Padding="6,2"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="WordTextBox_TextChanged"
                                                         GotKeyboardFocus="WordBox_GotKeyboardFocus"
                                                         LostKeyboardFocus="WordBox_LostKeyboardFocus">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Hidden"/>
                                                            <Setter Property="Text" Value="{Binding Text, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ElementName=ShowPhraseCheckBox, Path=IsChecked}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>

                                                <PasswordBox x:Name="WordPasswordBox"
                                                             Grid.Column="1"
                                                             Height="26"
                                                             Padding="6,2"
                                                             VerticalContentAlignment="Center"
                                                             PasswordChanged="WordPasswordBox_PasswordChanged"
                                                             GotKeyboardFocus="WordBox_GotKeyboardFocus"
                                                             LostKeyboardFocus="WordBox_LostKeyboardFocus">
                                                    <PasswordBox.Style>
                                                        <Style TargetType="PasswordBox">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ElementName=ShowPhraseCheckBox, Path=IsChecked}" Value="True">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </PasswordBox.Style>
                                                </PasswordBox>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="340"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Derivation path:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <ComboBox x:Name="DerivationPathComboBox"
                                      Grid.Column="1"
                                      Width="340"
                                      Height="26"
                                      VerticalContentAlignment="Center"
                                      SelectionChanged="RecoveryInputs_SelectionChanged">
                                <ComboBoxItem Content="XDC Standard (m/44'/550'/0'/0/i) — Default" Tag="m/44'/550'/0'/0/{i}"/>
                                <ComboBoxItem Content="Ethereum Compatible (m/44'/60'/0'/0/i)" Tag="m/44'/60'/0'/0/{i}"/>
                            </ComboBox>

                            <TextBlock Grid.Column="2"
                                       Text="Addresses:"
                                       VerticalAlignment="Center"
                                       Margin="18,0,6,0"/>

                            <ComboBox x:Name="ScanCountComboBox"
                                      Grid.Column="3"
                                      Width="70"
                                      Height="26"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="40"/>
                                <ComboBoxItem Content="50"/>
                            </ComboBox>

                            <Button x:Name="ScanNowButton"
                                    Grid.Column="4"
                                    Content="Scan now"
                                    Width="100"
                                    Margin="18,0,0,0"
                                    Padding="12,4"
                                    Click="ScanNowButton_Click"/>
                        </Grid>

                        <TextBlock x:Name="SelectAddressInstructionTextBlock"
                                   Grid.Row="1"
                                   Text="Select an address from the list below to continue."
                                   Margin="0,0,0,2"
                                   Foreground="#444"/>

                        <Border Grid.Row="2"
                                BorderBrush="#BFBFBF"
                                BorderThickness="1"
                                Background="White"
                                Padding="0">
                            <DataGrid x:Name="DerivedAddressesDataGrid"
                                      Height="164"
                                      VerticalAlignment="Top"
                                      BorderThickness="0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserResizeRows="False"
                                      CanUserResizeColumns="False"
                                      CanUserReorderColumns="False"
                                      CanUserSortColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      AlternatingRowBackground="#F7F7F7"
                                      RowBackground="White"
                                      GridLinesVisibility="All"
                                      VerticalGridLinesBrush="#E2E2E2"
                                      HorizontalGridLinesBrush="#E2E2E2"
                                      RowHeight="28"
                                      EnableRowVirtualization="True"
                                      ScrollViewer.CanContentScroll="True"
                                      SelectionChanged="DerivedAddressesDataGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Index"
                                                        Width="60"
                                                        Binding="{Binding Index}"
                                                        CanUserSort="False" />
                                    <DataGridTextColumn Header="Address (xdc)"
                                                        Width="*"
                                                        Binding="{Binding AddressXdc}"
                                                        CanUserSort="False" />
                                    <DataGridTextColumn Header="Balance (XDC)"
                                                        Width="120"
                                                        Binding="{Binding BalanceXdc}"
                                                        CanUserSort="False" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="4">
                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Left">
                            <TextBlock x:Name="SelectedAddressSummaryTextBlock"
                                       Text="Selected address: None"
                                       Margin="0,0,0,8"
                                       Foreground="#444"/>

                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="CopySelectedAddressButton"
                                        Content="Copy address"
                                        Width="120"
                                        Margin="0,0,10,0"
                                        Padding="12,4"
                                        Click="CopySelectedAddressButton_Click"
                                        IsEnabled="False"/>

                                <Button x:Name="CreateKeystoreSelectedButton"
                                        Content="Create keystore (selected)"
                                        Width="170"
                                        Margin="0,0,10,0"
                                        Padding="12,4"
                                        Click="CreateKeystoreSelectedButton_Click"
                                        IsEnabled="False"/>

                                <Button x:Name="ExportPrivateKeySelectedButton"
                                        Content="Export private key (selected)"
                                        Width="180"
                                        Padding="12,4"
                                        Click="ExportPrivateKeySelectedButton_Click"
                                        IsEnabled="False"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Private Key — Advanced">
                <Grid Margin="10">
                    <Border BorderBrush="#BFBFBF"
                            BorderThickness="1"
                            Padding="12"
                            Width="700"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="Transparent">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="420"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.ColumnSpan="4"
                                       Text="Private key authorisation allows access to a single address only.&#10;Anyone with this private key can control the wallet.&#10;For regular use, Keystore JSON is recommended."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <TextBlock x:Name="PrivateKeyValidationStatusTextBlock"
                                       Grid.Row="1"
                                       Grid.ColumnSpan="4"
                                       Text="Enter a private key and click Validate."
                                       Foreground="#666"
                                       Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Private key:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <Grid Grid.Row="2"
                                  Grid.Column="1">
                                <PasswordBox x:Name="PrivateKeyPasswordBox"
                                             Height="26"
                                             Padding="6,2"
                                             VerticalContentAlignment="Center"
                                             PasswordChanged="PrivateKeyInputs_Changed"/>

                                <TextBox x:Name="PrivateKeyTextBox"
                                         Height="26"
                                         Padding="6,2"
                                         VerticalContentAlignment="Center"
                                         Visibility="Collapsed"
                                         TextChanged="PrivateKeyInputs_Changed"/>
                            </Grid>

                            <TextBlock x:Name="PrivateKeyFormatTickTextBlock"
                                       Grid.Row="2"
                                       Grid.Column="2"
                                       Text="✔"
                                       FontSize="16"
                                       Foreground="#228B22"
                                       VerticalAlignment="Center"
                                       Margin="8,0,8,0"
                                       Visibility="Collapsed"/>

                            <Button x:Name="ValidatePrivateKeyButton"
                                    Grid.Row="2"
                                    Grid.Column="3"
                                    Content="Validate"
                                    Width="110"
                                    Height="26"
                                    Margin="8,0,0,0"
                                    Click="ValidatePrivateKeyButton_Click"
                                    IsEnabled="False"/>

                            <CheckBox x:Name="ShowPrivateKeyCheckBox"
                                      Grid.Row="3"
                                      Grid.Column="1"
                                      Margin="0,8,0,0"
                                      Content="Show private key"
                                      Checked="ShowPrivateKeyCheckBox_Checked"
                                      Unchecked="ShowPrivateKeyCheckBox_Unchecked"/>

                            <TextBlock Grid.Row="4"
                                       Grid.Column="0"
                                       Text="Address:"
                                       VerticalAlignment="Center"
                                       Margin="0,10,8,0"/>

                            <TextBox x:Name="PrivateKeyAddressTextBox"
                                     Grid.Row="4"
                                     Grid.Column="1"
                                     Height="26"
                                     Padding="6,2"
                                     VerticalContentAlignment="Center"
                                     IsReadOnly="True"
                                     Margin="0,10,0,0"/>

                            <Button x:Name="CopyPrivateKeyAddressButton"
                                    Grid.Row="4"
                                    Grid.Column="3"
                                    Content="Copy address"
                                    Width="110"
                                    Height="26"
                                    Margin="8,10,0,0"
                                    Click="CopyPrivateKeyAddressButton_Click"
                                    IsEnabled="False"/>

                            <Button x:Name="CreateKeystoreFromPrivateKeyButton"
                                    Grid.Row="5"
                                    Grid.Column="1"
                                    Content="Create keystore for this address"
                                    Width="230"
                                    Height="28"
                                    HorizontalAlignment="Left"
                                    Margin="0,14,0,0"
                                    Padding="12,4"
                                    Click="CreateKeystoreFromPrivateKeyButton_Click"
                                    IsEnabled="False"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="AuthoriseButton"
                    Content="Authorise"
                    MinWidth="90"
                    MinHeight="28"
                    Margin="0,0,8,0"
                    Click="Authorise_Click"
                    IsEnabled="False"/>
            <Button Content="Cancel"
                    MinWidth="90"
                    MinHeight="28"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>