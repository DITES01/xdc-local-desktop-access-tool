<Window x:Class="XdcLocalDesktopAccessTool.App.Views.Windows.ThankYouWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thank You"
        Width="440"
        Height="215"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Margin="12"
            Padding="18,16"
            Background="#FAFAFA"
            BorderBrush="#A6A6A6"
            BorderThickness="1"
            CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="340">

                <TextBlock Text="Thank you for supporting this project."
                           TextAlignment="Center"
                           FontSize="15"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Your donation helps keep the XDC Local Desktop Access Tool maintained and improved."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="#444"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Coffee levels restored. Development may continue."
                           TextAlignment="Center"
                           FontStyle="Italic"
                           FontSize="12"/>
            </StackPanel>

            <Button Grid.Row="1"
                    Content="Close"
                    Width="100"
                    Height="28"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0"
                    Click="Close_Click"/>
        </Grid>
    </Border>
</Window>