<Window x:Class="XdcLocalDesktopAccessTool.App.Views.Windows.CreateWalletWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:XdcLocalDesktopAccessTool.App.Controls"
        Title="Create new wallet"
        Width="1000"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="IMPORTANT: Write down your recovery phrase now."
                       FontWeight="Bold"
                       Margin="0,0,0,2"/>
            <TextBlock Text="You will be asked to verify it before closing this window."/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Phrase length"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <ComboBox x:Name="PhraseLengthComboBox"
                      Grid.Column="1"
                      Height="26"
                      VerticalAlignment="Center"
                      SelectedIndex="0"
                      SelectionChanged="PhraseLengthComboBox_SelectionChanged">
                <ComboBoxItem Content="12 words" Tag="12" IsSelected="True"/>
                <ComboBoxItem Content="24 words" Tag="24"/>
            </ComboBox>

            <TextBlock Grid.Column="3"
                       Text="Derivation path:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <ComboBox x:Name="DerivationPathComboBox"
                      Grid.Column="4"
                      Height="26"
                      VerticalAlignment="Center"
                      SelectedIndex="0"
                      SelectionChanged="DerivationPathComboBox_SelectionChanged">
                <ComboBoxItem Content="XDC Standard (m/44'/550'/0'/0/i) — Default" IsSelected="True"/>
                <ComboBoxItem Content="Ethereum Compatible (m/44'/60'/0'/0/i)"/>
            </ComboBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
            <CheckBox x:Name="ShowRecoveryPhraseCheckBox"
                      Content="Show recovery phrase"
                      Margin="0,0,18,0"
                      IsEnabled="False"
                      IsChecked="False"
                      Checked="ShowRecoveryPhraseCheckBox_Checked"
                      Unchecked="ShowRecoveryPhraseCheckBox_Unchecked"/>

            <CheckBox x:Name="UseBip39PassphraseCheckBox"
                      Content="Use BIP39 passphrase (advanced)"
                      IsChecked="False"
                      Checked="UseBip39PassphraseCheckBox_Checked"
                      Unchecked="UseBip39PassphraseCheckBox_Unchecked"/>
        </StackPanel>

        <Grid x:Name="Bip39RowGrid" Grid.Row="3" Margin="0,0,0,8" Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="BIP39 passphrase:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <Grid Grid.Row="0" Grid.Column="1" Margin="0,0,10,0">
                <PasswordBox x:Name="Bip39PassphrasePasswordBox"
                             Height="26"
                             Padding="6,2"
                             PasswordChanged="Bip39PassphrasePasswordBox_PasswordChanged"/>
                <TextBox x:Name="Bip39PassphraseTextBox"
                         Height="26"
                         Padding="6,2"
                         Visibility="Collapsed"
                         TextChanged="Bip39PassphraseTextBox_TextChanged"/>
            </Grid>

            <CheckBox x:Name="ShowBip39PassphraseCheckBox"
                      Grid.Row="0"
                      Grid.Column="3"
                      Content="Show passphrase"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Left"
                      IsChecked="False"
                      IsEnabled="False"
                      Checked="ShowBip39PassphraseCheckBox_Checked"
                      Unchecked="ShowBip39PassphraseCheckBox_Unchecked"/>

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="Confirm passphrase:"
                       VerticalAlignment="Center"
                       Margin="0,8,6,0"/>

            <Grid Grid.Row="1" Grid.Column="1" Margin="0,8,10,0">
                <PasswordBox x:Name="ConfirmBip39PassphrasePasswordBox"
                             Height="26"
                             Padding="6,2"
                             PasswordChanged="ConfirmBip39PassphrasePasswordBox_PasswordChanged"/>
                <TextBox x:Name="ConfirmBip39PassphraseTextBox"
                         Height="26"
                         Padding="6,2"
                         Visibility="Collapsed"
                         TextChanged="ConfirmBip39PassphraseTextBox_TextChanged"/>
            </Grid>
        </Grid>

        <GroupBox Grid.Row="4" Header="Recovery phrase" Margin="0,0,0,10">
            <Border BorderBrush="#6F6F6F"
                    BorderThickness="1"
                    Padding="6">
                <controls:MnemonicPhraseGrid x:Name="MnemonicGridControl"/>
            </Border>
        </GroupBox>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#6F6F6F"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,10,0">
                <TextBlock x:Name="OutputTextBlock"
                           Text="Address and derivation path will appear here..."
                           Foreground="#666"/>
            </Border>

            <StackPanel Grid.Column="1">
                <Button x:Name="CreateNewWalletButton"
                        Content="Create new wallet"
                        Width="180"
                        Height="30"
                        Margin="0,0,0,8"
                        Click="CreateNewWalletButton_Click"/>

                <Button x:Name="CopyAddressButton"
                        Content="Copy address"
                        Width="180"
                        Height="30"
                        Margin="0,0,0,8"
                        IsEnabled="False"
                        Click="CopyAddressButton_Click"/>

                <Button x:Name="CopyRecoveryPhraseButton"
                        Content="Copy recovery phrase"
                        Width="180"
                        Height="30"
                        Margin="0,0,0,8"
                        IsEnabled="False"
                        Click="CopyRecoveryPhraseButton_Click"/>

                <Button Content="Close"
                        Width="180"
                        Height="30"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>