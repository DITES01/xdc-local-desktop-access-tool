<Window x:Class="XdcLocalDesktopAccessTool.App.Views.Windows.GenerateKeystoreFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Generate keystore file"
        Width="1000"
        Height="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="34"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="IMPORTANT: Generate and store your keystore file safely."
                           FontWeight="Bold"
                           Margin="0,0,0,2"/>
                <TextBlock x:Name="SelectedAddressHeaderTextBlock"
                           Text="Selected address: Derived on create (index 0)"
                           FontWeight="SemiBold"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Phrase length"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <ComboBox x:Name="PhraseLengthComboBox"
                      Grid.Column="1"
                      SelectedIndex="0"
                      Height="26"
                      VerticalAlignment="Center"
                      SelectionChanged="PhraseLengthComboBox_SelectionChanged">
                <ComboBoxItem Content="12 words" IsSelected="True"/>
                <ComboBoxItem Content="24 words"/>
            </ComboBox>

            <TextBlock Grid.Column="3"
                       Text="Derivation path:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <ComboBox x:Name="DerivationPathComboBox"
                      Grid.Column="4"
                      Height="26"
                      VerticalAlignment="Center"
                      SelectedIndex="0"
                      SelectionChanged="DerivationPathComboBox_SelectionChanged">
                <ComboBoxItem Content="XDC Standard (m/44'/550'/0'/0/i) — Default" Tag="m/44'/550'/0'/0/{i}" IsSelected="True"/>
                <ComboBoxItem Content="Ethereum Compatible (m/44'/60'/0'/0/i)" Tag="m/44'/60'/0'/0/{i}"/>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="ShowPhraseCheckBox"
                      Grid.Column="0"
                      Content="Show phrase while typing"
                      VerticalAlignment="Center"
                      Checked="ShowPhraseCheckBox_Changed"
                      Unchecked="ShowPhraseCheckBox_Changed"/>

            <CheckBox x:Name="UsePassphraseCheckBox"
                      Grid.Column="2"
                      Content="This wallet uses a BIP39 passphrase (advanced)"
                      VerticalAlignment="Center"
                      Checked="UsePassphraseCheckBox_Changed"
                      Unchecked="UsePassphraseCheckBox_Changed"/>
        </Grid>

        <Grid x:Name="PassphraseRowGrid"
              Grid.Row="3"
              Margin="0,0,0,6"
              Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="BIP39 passphrase:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <Grid Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center">
                <PasswordBox x:Name="PassphrasePasswordBox"
                             Height="26"
                             Padding="6,2"
                             PasswordChanged="PassphrasePasswordBox_PasswordChanged"
                             ToolTip="Optional BIP39 passphrase (extra security; sometimes called the 25th word)"/>

                <TextBox x:Name="PassphrasePlainTextBox"
                         Height="26"
                         Padding="6,2"
                         VerticalContentAlignment="Center"
                         Visibility="Collapsed"
                         TextChanged="PassphrasePlainTextBox_TextChanged"
                         ToolTip="Optional BIP39 passphrase (extra security; sometimes called the 25th word)"/>
            </Grid>

            <CheckBox x:Name="ShowPassphraseCheckBox"
                      Grid.Column="4"
                      Content="Show passphrase"
                      VerticalAlignment="Center"
                      IsChecked="False"
                      IsEnabled="False"
                      Margin="12,0,0,0"
                      Checked="ShowPassphraseCheckBox_Checked"
                      Unchecked="ShowPassphraseCheckBox_Unchecked"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="New keystore password:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <Grid Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center">
                <PasswordBox x:Name="KeystorePasswordBox"
                             Height="26"
                             Padding="6,2"
                             PasswordChanged="KeystorePasswordBox_PasswordChanged"/>

                <TextBox x:Name="KeystorePasswordPlainTextBox"
                         Height="26"
                         Padding="6,2"
                         VerticalContentAlignment="Center"
                         Visibility="Collapsed"
                         TextChanged="KeystorePasswordPlainTextBox_TextChanged"/>
            </Grid>

            <CheckBox x:Name="ShowKeystorePasswordsCheckBox"
                      Grid.Column="4"
                      Content="Show passwords"
                      VerticalAlignment="Center"
                      IsChecked="False"
                      Margin="12,0,0,0"
                      Checked="ShowKeystorePasswordsCheckBox_Checked"
                      Unchecked="ShowKeystorePasswordsCheckBox_Unchecked"/>
        </Grid>

        <Grid Grid.Row="5" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Confirm new password:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <Grid Grid.Column="1" Grid.ColumnSpan="2" VerticalAlignment="Center">
                <PasswordBox x:Name="ConfirmKeystorePasswordBox"
                             Height="26"
                             Padding="6,2"
                             PasswordChanged="ConfirmKeystorePasswordBox_PasswordChanged"/>

                <TextBox x:Name="ConfirmKeystorePasswordPlainTextBox"
                         Height="26"
                         Padding="6,2"
                         VerticalContentAlignment="Center"
                         Visibility="Collapsed"
                         TextChanged="ConfirmKeystorePasswordPlainTextBox_TextChanged"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="6" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Save location:"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>

            <TextBox x:Name="KeystorePathTextBox"
                     Grid.Column="1"
                     Grid.ColumnSpan="2"
                     Height="26"
                     Padding="6,2"
                     VerticalContentAlignment="Center"
                     IsReadOnly="True"
                     Text="Select a save location..."
                     Foreground="#666"/>

            <Button x:Name="BrowseKeystorePathButton"
                    Grid.Column="4"
                    Content="Browse..."
                    Width="110"
                    Height="26"
                    HorizontalAlignment="Left"
                    Margin="12,0,0,0"
                    Click="BrowseKeystorePathButton_Click"/>
        </Grid>

        <Grid Grid.Row="7" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Enter your recovery phrase below (12 or 24 words)"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>

            <Border Grid.Row="1"
                    BorderBrush="#6F6F6F"
                    BorderThickness="1"
                    Padding="4">

                <ItemsControl x:Name="WordsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" Rows="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="WordCellRoot" Margin="5,1,5,1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="26"
                                            Height="26"
                                            VerticalAlignment="Center"
                                            BorderBrush="#D0D0D0"
                                            BorderThickness="1"
                                            Background="#F7F7F7"
                                            Margin="0,0,6,0">
                                        <TextBlock Text="{Binding DisplayIndex}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#333"/>
                                    </Border>

                                    <TextBox x:Name="WordTextBox"
                                             Grid.Column="1"
                                             Height="26"
                                             Padding="6,2"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="WordTextBox_TextChanged"
                                             GotKeyboardFocus="WordBox_GotKeyboardFocus"
                                             LostKeyboardFocus="WordBox_LostKeyboardFocus"
                                             Visibility="Hidden"/>

                                    <PasswordBox x:Name="WordPasswordBox"
                                                 Grid.Column="1"
                                                 Height="26"
                                                 Padding="6,2"
                                                 VerticalContentAlignment="Center"
                                                 PasswordChanged="WordPasswordBox_PasswordChanged"
                                                 GotKeyboardFocus="WordBox_GotKeyboardFocus"
                                                 LostKeyboardFocus="WordBox_LostKeyboardFocus"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Border>
        </Grid>

        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#6F6F6F"
                    BorderThickness="1"
                    Padding="10">
                <TextBox x:Name="OutputTextBlock"
                         Text="Keystore file details will appear here..."
                         Foreground="#666"
                         TextWrapping="Wrap"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         BorderThickness="0"
                         Background="Transparent"/>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1">
                    <Button x:Name="CopyAddressButton"
                            Content="Copy address"
                            Width="180"
                            Height="30"
                            Margin="0,0,0,8"
                            Click="CopyAddressButton_Click"/>

                    <Button Content="Create keystore"
                            Width="180"
                            Height="30"
                            Margin="0,0,0,8"
                            Click="CreateKeystore_Click"/>

                    <Button Content="Cancel"
                            Width="180"
                            Height="30"
                            IsCancel="True"
                            Click="Cancel_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
