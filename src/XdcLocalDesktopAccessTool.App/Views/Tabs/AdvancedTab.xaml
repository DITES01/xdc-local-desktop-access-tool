<UserControl x:Class="XdcLocalDesktopAccessTool.App.Views.Tabs.AdvancedTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource MainTabContainerStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Margin="0,0,0,20">
                <TextBlock Text="Advanced"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <StackPanel MaxWidth="760">
                    <TextBlock FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4">
• Create a new wallet using a 12 or 24 word recovery phrase. An optional BIP39 passphrase can also be used for advanced setups.
                    </TextBlock>

                    <TextBlock FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4">
• Verify that your recovery phrase has been written down correctly before using the wallet.
                    </TextBlock>

                    <TextBlock FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,4">
• Generate an encrypted keystore JSON file from a wallet. This can be used for secure everyday access without exposing the recovery phrase.
                    </TextBlock>

                    <TextBlock FontSize="13"
                               TextWrapping="Wrap">
• By default, keystore generation uses the primary derived address (index 0). Advanced users can authorise with a recovery phrase and select different derived addresses if required.
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,8,0,0">
                <Button x:Name="CreateWalletButton"
                        Content="Create New Wallet"
                        Width="220"
                        Height="34"
                        Margin="0,0,0,10"
                        Click="CreateWalletButton_Click"/>

                <Button x:Name="GenerateKeystoreButton"
                        Content="Generate Keystore File"
                        Width="220"
                        Height="34"
                        Click="GenerateKeystoreButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>