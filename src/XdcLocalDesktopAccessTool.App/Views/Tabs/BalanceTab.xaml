<UserControl x:Class="XdcLocalDesktopAccessTool.App.Views.Tabs.BalanceTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Border BorderBrush="#A6A6A6"
            BorderThickness="1"
            CornerRadius="10"
            Margin="6"
            Padding="10"
            SnapsToDevicePixels="True">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Address (XDC):"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <Grid Grid.Column="1">
                    <TextBox x:Name="AddressTextBox"
                             MinHeight="28"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Padding="4,0,22,0"
                             TextChanged="AddressTextBox_TextChanged"/>

                    <TextBlock x:Name="AddressValidTick"
                               Text="✔"
                               FontSize="16"
                               Foreground="Green"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,6,0"
                               Visibility="Hidden"/>
                </Grid>

                <Button x:Name="CheckBalanceButton"
                        Grid.Column="3"
                        Content="Check Balance"
                        Padding="14,6"
                        Click="CheckBalance_Click"/>

                <Button x:Name="ViewOnExplorerButton"
                        Grid.Column="5"
                        Content="View on XDCScan"
                        Padding="14,6"
                        IsEnabled="False"
                        Click="ViewOnExplorer_Click"/>

                <Button x:Name="ClearButton"
                        Grid.Column="7"
                        Content="Clear"
                        MinWidth="80"
                        Padding="14,6"
                        Margin="0,0,2,0"
                        HorizontalAlignment="Left"
                        IsEnabled="False"
                        Click="Clear_Click"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="RPC:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <ComboBox x:Name="RpcModeComboBox"
                          Grid.Column="1"
                          MinHeight="28"
                          Height="28"
                          VerticalContentAlignment="Center"
                          SelectionChanged="RpcMode_SelectionChanged">
                    <ComboBoxItem Content="Default" IsSelected="True"/>
                    <ComboBoxItem Content="Custom"/>
                </ComboBox>

                <TextBox x:Name="CustomRpcTextBox"
                         Grid.Column="2"
                         Margin="8,0,0,0"
                         MinHeight="28"
                         Height="28"
                         VerticalContentAlignment="Center"
                         IsEnabled="False"/>
            </Grid>

            <TextBox x:Name="BalanceTextBlock"
                     Grid.Row="2"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     FontSize="13"/>

        </Grid>
    </Border>
</UserControl>
