<UserControl x:Class="XdcLocalDesktopAccessTool.App.Views.Tabs.AboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="#A6A6A6"
            BorderThickness="1"
            CornerRadius="10"
            Margin="6"
            Padding="12">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <TextBlock Text="About"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <!-- CONTENT -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="0,0,10,0">

                    <TextBlock TextWrapping="Wrap"
                               Margin="0,0,0,12">
XDC Local Desktop Access Tool is a local-only wallet utility for interacting with the XDC Network.

All wallet operations occur locally on your computer. Private keys, recovery phrases and keystore passwords are never transmitted to external servers.
                    </TextBlock>

                    <TextBlock FontWeight="Bold"
                               Margin="0,0,0,4">
Features:
                    </TextBlock>

                    <StackPanel Margin="0,0,0,12">

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Balance checking via public XDC RPC (Chain ID 50)"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Local transaction signing"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Secure authorisation required before transactions can be sent"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Keystore JSON generation for encrypted wallet storage"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Recovery phrase support with optional BIP39 passphrase"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Multiple address derivation and scanning"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Configurable gas modes (Auto or Custom)"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Explorer integration using XDCScan"
                                       TextWrapping="Wrap"/>
                        </Grid>

                    </StackPanel>

                    <TextBlock FontWeight="Bold"
                               Margin="0,0,0,4">
Security Model:
                    </TextBlock>

                    <StackPanel Margin="0,0,0,12">

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="No accounts"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="No background services"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="No telemetry"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="No remote storage of secrets"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <TextBlock TextWrapping="Wrap">
Everything runs locally and remains under the user's control.
                        </TextBlock>

                    </StackPanel>

                    <TextBlock FontWeight="Bold"
                               Margin="0,0,0,4">
Tips:
                    </TextBlock>

                    <StackPanel Margin="0,0,0,8">

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Use a keystore file for everyday use."
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="Store recovery phrases and passphrases offline and securely."
                                       TextWrapping="Wrap"/>
                        </Grid>

                    </StackPanel>

                </StackPanel>

            </ScrollViewer>

            <!-- FOOTER -->
            <Grid Grid.Row="2"
                  Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- COPYRIGHT -->
                <TextBlock Text="© 2026 David McDougall – XDC Local Desktop Access Tool"
                           FontSize="11"
                           Foreground="#666"
                           VerticalAlignment="Center"/>

                <!-- SUPPORT BUTTON -->
                <Button Grid.Column="1"
                        Content="Support This Tool"
                        Width="150"
                        Height="28"
                        Click="SupportThisTool_Click"/>

            </Grid>

        </Grid>

    </Border>

</UserControl>