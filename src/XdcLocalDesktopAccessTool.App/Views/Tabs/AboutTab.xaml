<UserControl x:Class="XdcLocalDesktopAccessTool.App.Views.Tabs.AboutTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#F4F4F4"
            BorderBrush="#BFBFBF"
            BorderThickness="1"
            CornerRadius="8"
            Margin="6"
            Padding="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="About"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

                        <StackPanel Grid.Row="1">

                <TextBlock TextWrapping="Wrap"
                           Margin="0,0,0,14">
                    XDC Local Desktop Access Tool is a local-only desktop utility for interacting with the XDC Network.

All wallet operations occur locally on your computer. Private keys, recovery phrases and keystore passwords are never transmitted to external servers.
                </TextBlock>

                <Border BorderBrush="#6F6F6F"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,6"
                                   Text="Key Features"/>

                        <TextBlock Text="- Balance checking via public XDC RPC" Margin="0,0,0,3"/>
                        <TextBlock Text="- Local transaction signing" Margin="0,0,0,3"/>
                        <TextBlock Text="- Secure authorisation required before sending transactions" Margin="0,0,0,3"/>
                        <TextBlock Text="- Keystore JSON generation for encrypted wallet storage" Margin="0,0,0,3"/>
                        <TextBlock Text="- Recovery phrase support with optional BIP39 passphrase" Margin="0,0,0,3"/>
                        <TextBlock Text="- Multiple address derivation and scanning" Margin="0,0,0,3"/>
                        <TextBlock Text="- Explorer integration using XDCScan"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#6F6F6F"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,6"
                                   Text="Security Model"/>

                        <TextBlock Text="- No accounts" Margin="0,0,0,3"/>
                        <TextBlock Text="- No background services" Margin="0,0,0,3"/>
                        <TextBlock Text="- No telemetry" Margin="0,0,0,3"/>
                        <TextBlock Text="- No remote storage of secrets" Margin="0,0,0,8"/>

                        <TextBlock Text="Everything runs locally and remains fully under the user's control."
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#6F6F6F"
                        BorderThickness="1"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="Local-first design"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>

                        <TextBlock TextWrapping="Wrap"
                                   Margin="0,0,0,10">
                            This tool is designed to keep signing activity and wallet-sensitive operations on your own machine.
                        </TextBlock>

                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,6"
                                   Text="Core approach"/>

                        <TextBlock Text="- Local signing only" Margin="0,0,0,3"/>
                        <TextBlock Text="- Secrets kept in memory only" Margin="0,0,0,3"/>
                        <TextBlock Text="- No browser-wallet dependency" Margin="0,0,0,3"/>
                        <TextBlock Text="- No background services or telemetry" Margin="0,0,0,10"/>

                        <TextBlock FontWeight="SemiBold"
                                   Margin="0,0,0,6"
                                   Text="Best used for"/>

                        <TextBlock Text="- Checking balances" Margin="0,0,0,3"/>
                        <TextBlock Text="- Sending transactions with local signing" Margin="0,0,0,3"/>
                        <TextBlock Text="- Creating keystore files from recovery data" Margin="0,0,0,3"/>
                        <TextBlock Text="- Working with derived XDC addresses"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <Grid Grid.Row="2"
                  Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="(c) 2026 David McDougall - XDC Local Desktop Access Tool"
                           FontSize="11"
                           Foreground="#666"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Support This Tool"
                        Width="150"
                        Height="30"
                        Click="SupportThisTool_Click"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>




