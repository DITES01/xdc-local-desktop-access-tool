<UserControl x:Class="XdcLocalDesktopAccessTool.App.Views.Tabs.SendTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="#A6A6A6"
            BorderThickness="1"
            CornerRadius="10"
            Margin="6"
            Padding="10">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ================================================= -->
            <!-- BALANCE -->
            <!-- ================================================= -->

            <StackPanel Grid.Row="0" Margin="0,0,0,12">

                <TextBlock Text="Balance"
                           FontSize="15"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="105"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="125"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Address (XDC):"
                               VerticalAlignment="Center"/>

                    <Grid Grid.Column="1">
                        <TextBox x:Name="BalanceAddressTextBox"
                                 TextChanged="BalanceAddressTextBox_TextChanged"
                                 Height="26"
                                 Padding="6,2,22,2"
                                 VerticalContentAlignment="Center"/>

                        <TextBlock x:Name="BalanceAddressValidTick"
                                   Text="✔"
                                   FontSize="16"
                                   Foreground="Green"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,6,0"
                                   Visibility="Hidden"/>
                    </Grid>

                    <Button x:Name="CheckBalanceButton"
                            Click="CheckBalance_Click"
                            Grid.Column="3"
                            Content="Check Balance"
                            Height="26"
                            IsEnabled="False"/>

                    <Button x:Name="ViewOnExplorerButton"
                            Click="ViewOnExplorerButton_Click"
                            Grid.Column="5"
                            Content="View on XDCScan"
                            Height="26"
                            IsEnabled="False"/>

                    <Button x:Name="BalanceClearButton"
                            Click="BalanceClearButton_Click"
                            Grid.Column="7"
                            Content="Clear"
                            Height="26"
                            IsEnabled="False"/>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="RPC:"
                               VerticalAlignment="Center"/>

                    <ComboBox x:Name="RpcModeComboBox"
                              SelectionChanged="RpcModeComboBox_SelectionChanged"
                              Grid.Column="1"
                              Height="26"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Default" IsSelected="True"/>
                        <ComboBoxItem Content="Custom"/>
                    </ComboBox>

                    <TextBox x:Name="CustomRpcTextBox"
                             Grid.Column="2"
                             Margin="8,0,0,0"
                             Height="26"
                             VerticalContentAlignment="Center"
                             TextChanged="CustomRpcTextBox_TextChanged"
                             IsEnabled="False"/>
                </Grid>

                <TextBox x:Name="BalanceTextBlock"
                         Height="120"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="13"
                         BorderBrush="#A6A6A6"
                         BorderThickness="1"
                         Background="White"/>

                <Rectangle Height="3"
                           Fill="#A6A6A6"
                           Margin="0,16,0,12"/>
            </StackPanel>

            <!-- ================================================= -->
            <!-- HEADER / AUTHORISATION AREA -->
            <!-- ================================================= -->

            <Grid Grid.Row="1" Margin="0,0,0,10">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">

                    <TextBlock Text="Send"
                               FontSize="15"
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>

                    <TextBlock x:Name="AuthorisationStatusText"
                               FontWeight="SemiBold"
                               Margin="0,2,0,6"
                               Text="Not authorised"/>

                    <Grid x:Name="FromRow">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="From:"
                                   VerticalAlignment="Center"/>

                        <TextBox x:Name="FromAddressTextBox"
                                 Grid.Column="1"
                                 Height="26"
                                 Padding="6,2"
                                 VerticalContentAlignment="Center"
                                 IsReadOnly="True"/>

                    </Grid>

                </StackPanel>

                <!-- RIGHT SIDE BUTTON AREA -->
                <Grid Grid.Column="1"
                      VerticalAlignment="Bottom"
                      Margin="0,0,0,0"
                      HorizontalAlignment="Right">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CopyAddressButton"
                            Grid.Column="0"
                            Width="110"
                            Height="28"
                            Content="Copy Address"
                            Click="CopyAddress_Click"/>

                    <Grid Grid.Column="2"
                          Width="170"
                          Height="28">

                        <Button x:Name="AuthoriseButton"
                                Content="Authorise (local signing)"
                                Width="170"
                                Height="28"
                                Visibility="Visible"
                                Click="Authorise_Click"/>

                        <Button x:Name="DeauthoriseButton"
                                Content="Deauthorise"
                                Width="170"
                                Height="28"
                                Visibility="Collapsed"
                                Click="Deauthorise_Click"/>

                    </Grid>

                </Grid>

            </Grid>

            <!-- ================================================= -->
            <!-- TO ADDRESS -->
            <!-- ================================================= -->

            <Grid Grid.Row="2" Margin="0,0,0,8">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="To Address"
                           VerticalAlignment="Center"/>

                <Grid Grid.Column="1">

                    <TextBox x:Name="ToAddressTextBox"
                             Height="26"
                             Padding="6,2,22,2"
                             VerticalContentAlignment="Center"
                             TextChanged="ToAddressTextBox_TextChanged"/>

                    <TextBlock x:Name="ToAddressValidTick"
                               Text="✔"
                               FontSize="16"
                               Foreground="Green"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Margin="0,0,6,0"
                               Visibility="Hidden"/>

                </Grid>

                <Button x:Name="ViewToAddressButton"
                        Grid.Column="3"
                        Width="130"
                        Height="26"
                        Content="View on XDCScan"
                        Click="ViewToAddress_Click"/>

                <Button x:Name="ClearButton"
                        Grid.Column="5"
                        Width="90"
                        Height="26"
                        Content="Clear"
                        Click="Clear_Click"/>

            </Grid>

            <!-- ================================================= -->
            <!-- AMOUNT -->
            <!-- ================================================= -->

            <Grid Grid.Row="3" Margin="0,0,0,8">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Amount (XDC)"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="AmountTextBox"
                         Grid.Column="1"
                         Height="26"
                         Padding="6,2"
                         VerticalContentAlignment="Center"
                         TextChanged="AmountTextBox_TextChanged"/>

            </Grid>

            <!-- ================================================= -->
            <!-- GAS MODE -->
            <!-- ================================================= -->

            <Grid Grid.Row="4" Margin="0,0,0,6">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Gas / Fee Mode"
                           VerticalAlignment="Center"/>

                <ComboBox x:Name="GasModeCombo"
                          Grid.Column="1"
                          Height="26"
                          VerticalContentAlignment="Center"
                          SelectionChanged="GasMode_SelectionChanged">

                    <ComboBoxItem Content="Auto" IsSelected="True"/>
                    <ComboBoxItem Content="Custom"/>

                </ComboBox>

            </Grid>

            <!-- ================================================= -->
            <!-- GAS PRICE -->
            <!-- ================================================= -->

            <Grid Grid.Row="5" Margin="0,0,0,2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="GasPriceLabel"
                           Text="Gas Price (Gwei)"
                           VerticalAlignment="Center"/>

                <TextBox x:Name="CustomGasTextBox"
                         Grid.Column="1"
                         Height="26"
                         Padding="6,2"
                         VerticalContentAlignment="Center"
                         Visibility="Hidden"
                         TextChanged="CustomGasTextBox_TextChanged"/>

            </Grid>

            <!-- ================================================= -->
            <!-- SUGGESTED GAS -->
            <!-- ================================================= -->

            <TextBlock x:Name="SuggestedGasText"
                       Grid.Row="6"
                       Margin="140,2,0,8"
                       Foreground="Black"
                       Text="Suggested gas: -"/>

            <!-- ================================================= -->
            <!-- ACTION BUTTONS -->
            <!-- ================================================= -->

            <StackPanel Grid.Row="7"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">

                <Button x:Name="PreviewButton"
                        Content="Preview"
                        Width="90"
                        Height="28"
                        Margin="0,0,8,0"
                        Click="Preview_Click"/>

                <Button x:Name="SendButton"
                        Content="Send"
                        Width="90"
                        Height="28"
                        Margin="0,0,8,0"
                        Click="Send_Click"/>

                <Button x:Name="ViewLastTxButton"
                        Content="View Last Tx"
                        Width="110"
                        Height="28"
                        Click="ViewLastTx_Click"/>

            </StackPanel>

            <!-- ================================================= -->
            <!-- OUTPUT -->
            <!-- ================================================= -->

            <TextBox x:Name="OutputText"
                     Grid.Row="8"
                     VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     IsReadOnly="True"/>

        </Grid>

    </Border>

</UserControl>




