<Window x:Class="XdcLocalDesktopAccessTool.App.Views.Tabs.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Support This Tool"
        Width="640"
        Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Message -->
        <TextBlock Grid.Row="0"
                   Text="If this tool has helped you, feel free to buy me a coffee."
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12"/>

        <!-- Main panel -->
        <Border Grid.Row="1"
                Background="#F5F5F5"
                BorderBrush="#A0A0A0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="18">

            <StackPanel>

                <!-- Logo -->
                <Image x:Name="LogoImage"
                       Height="300"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       Margin="0,6,0,20"/>

                <!-- Donation -->
                <GroupBox Header="Donation address (XDC)"
                          Padding="12">

                    <StackPanel>

                        <TextBox x:Name="DonationAddressTextBox"
                                 Height="28"
                                 IsReadOnly="True"
                                 TextAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,10"
                                 Text="xdcd8DFc137957CaCe772021a84019E658DEFECFC43"/>

                        <Button Content="Copy address"
                                Width="130"
                                Height="30"
                                HorizontalAlignment="Center"
                                Click="CopyAddress_Click"/>

                    </StackPanel>

                </GroupBox>

            </StackPanel>

        </Border>

        <!-- Close -->
        <Button Grid.Row="2"
                Content="Close"
                Width="90"
                Height="28"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Click="Close_Click"/>

    </Grid>

</Window>