<Window x:Class="XdcLocalDesktopAccessTool.App.Views.Tabs.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Support This Tool"
        Width="560" Height="545"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Coffee line -->
        <TextBlock Grid.Row="0"
                   Text="If this tool has helped you, feel free to buy me a coffee."
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <!-- Main rounded panel -->
        <Border Grid.Row="1"
                CornerRadius="6"
                BorderThickness="1"
                Background="#F5F5F5"
                BorderBrush="#A0A0A0"
                Padding="14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Image x:Name="LogoImage"
                       Grid.Row="0"
                       Height="260"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       SnapsToDevicePixels="True"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,12"/>

                <!-- Donation -->
                <GroupBox Grid.Row="1"
                          Header="Donation address (XDC)"
                          Padding="10">
                    <StackPanel>
                        <TextBox x:Name="DonationAddressTextBox"
                                 Height="26"
                                 VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 TextAlignment="Center"
                                 IsReadOnly="True"
                                 Margin="0,0,0,8"
                                 Text="xdcd8DFc137957CaCe772021a84019E658DEFECCF43"/>

                        <Button Content="Copy address"
                                Width="120"
                                Height="28"
                                HorizontalAlignment="Center"
                                Margin="0,2,0,0"
                                Click="CopyAddress_Click"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Border>

        <!-- Close -->
        <Button Grid.Row="2"
                Content="Close"
                Width="90"
                Height="28"
                HorizontalAlignment="Right"
                Margin="0,10,0,0"
                Click="Close_Click"/>
    </Grid>
</Window>
