<Window x:Class="XdcLocalDesktopAccessTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:XdcLocalDesktopAccessTool.App.Views.Tabs"
        xmlns:controls="clr-namespace:XdcLocalDesktopAccessTool.App.Views.Controls"
        Title="XDC Desktop Access Tool"
        Width="1080"
        Height="940"
        MinWidth="1080"
        MinHeight="940"
        MaxWidth="1080"
        MaxHeight="940"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="12"
        Icon="Assets/Images/XDC_Icon_X.ico">

    <Grid>

        <TabControl x:Name="MainTabs"
                    SelectionChanged="MainTabs_SelectionChanged">

            

            <TabItem Header="Balance / Send"
                     x:Name="SendTabItem"
                     PreviewMouseLeftButtonDown="TabItem_PreviewMouseLeftButtonDown">
                <tabs:SendTab x:Name="SendTabControl"/>
            </TabItem>

            <TabItem Header="Advanced"
                     PreviewMouseLeftButtonDown="TabItem_PreviewMouseLeftButtonDown">
                <tabs:AdvancedTab/>
            </TabItem>

            <TabItem Header="About"
                     PreviewMouseLeftButtonDown="TabItem_PreviewMouseLeftButtonDown">
                <tabs:AboutTab/>
            </TabItem>

        </TabControl>

        <Grid x:Name="OverlayHost"
              Background="#66000000"
              Visibility="Collapsed"
              IsHitTestVisible="True"
              Focusable="True"
              KeyboardNavigation.TabNavigation="Cycle"
              Panel.ZIndex="100">

            <!-- Existing working support overlay -->
            <controls:SupportOverlayControl x:Name="SupportOverlay"
                                            Visibility="Collapsed"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Panel.ZIndex="1"/>

            <!-- Reusable in-window modal host -->
            <ContentControl x:Name="ModalOverlayPresenter"
                            Visibility="Collapsed"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Panel.ZIndex="2"/>

        </Grid>

    </Grid>
</Window>






